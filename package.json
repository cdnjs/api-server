{
    "name": "api-server",
    "version": "1.0.0",
    "description": "The new API server for api.cdnjs.com",
    "private": true,
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "prepare": "npm run prepare:husky && npm run prepare:types",
        "prepare:husky": "husky",
        "prepare:types": "wrangler types",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "test": "vitest run",
        "types": "tsc --noEmit",
        "dev": "wrangler dev"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cdnjs/api-server.git"
    },
    "author": "cdnjs",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/cdnjs/api-server/issues"
    },
    "homepage": "https://github.com/cdnjs/api-server#readme",
    "engines": {
        "node": ">=24.11.0"
    },
    "dependencies": {
        "@emotion/css": "^11.13.5",
        "@sentry/cloudflare": "^10.46.0",
        "algoliasearch": "^5.50.0",
        "hono": "^4.12.14",
        "is-deflate": "^1.0.0",
        "is-gzip": "^2.0.0",
        "pako": "^2.1.0",
        "semver": "^7.7.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.13.5",
        "@eslint/js": "^10.0.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/is-deflate": "^1.0.0",
        "@types/is-gzip": "^2.0.2",
        "@types/node": "~24.12.0",
        "@types/pako": "^2.0.4",
        "@types/semver": "^7.7.1",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.8.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.1.2",
        "wrangler": "^4.78.0"
    },
    "overrides": {
        "@cloudflare/vitest-pool-workers": {
            "wrangler": "$wrangler"
        }
    }
}
