{
    "name": "api-server",
    "version": "1.0.0",
    "description": "The new API server for api.cdnjs.com",
    "private": true,
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "prepare": "npm run prepare:husky && npm run prepare:types",
        "prepare:husky": "husky",
        "prepare:types": "wrangler types",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "test": "vitest run",
        "types": "tsc --noEmit",
        "dev": "wrangler dev"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cdnjs/api-server.git"
    },
    "author": "cdnjs",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/cdnjs/api-server/issues"
    },
    "homepage": "https://github.com/cdnjs/api-server#readme",
    "engines": {
        "node": ">=24.11.0"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@emotion/css": "^11.13.5",
        "@sentry/cloudflare": "^10.62.0",
        "@tanstack/react-virtual": "^3.14.4",
        "algoliasearch": "^5.55.1",
        "hono": "^4.12.27",
        "is-deflate": "^1.0.0",
        "is-gzip": "^2.0.0",
        "pako": "^3.0.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "semver": "^7.7.4",
        "spdx-license-ids": "^3.0.23",
        "swagger-ui-react": "^5.32.8",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.16.20",
        "@eslint/js": "^10.0.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/is-deflate": "^1.0.0",
        "@types/is-gzip": "^2.0.2",
        "@types/node": "~24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/semver": "^7.7.1",
        "@types/spdx-license-ids": "^3.0.0",
        "@types/swagger-ui-react": "^5.18.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^63.0.10",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "vitest": "^4.1.2",
        "wrangler": "^4.105.0"
    },
    "overrides": {
        "@cloudflare/vitest-pool-workers": {
            "wrangler": "$wrangler"
        },
        "swagger-ui-react": {
            "react-copy-to-clipboard": {
                "react": "$react"
            },
            "react-debounce-input": {
                "react": "$react"
            },
            "react-inspector": {
                "react": "$react"
            }
        }
    }
}
